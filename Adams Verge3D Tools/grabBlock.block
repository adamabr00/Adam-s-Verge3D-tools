  };

  const onMmbDownGrab = function (e) {
    if (!dragging) return;
    var btn = e.button !== undefined ? e.button : (e.which !== undefined ? e.which - 1 : -1);
    if (btn !== 1) return;
    var now = Date.now();
    if (now - lastMmbDownTs < 80) return;
    lastMmbDownTs = now;
    e.preventDefault();
    e.stopPropagation();
    if (e.stopImmediatePropagation) e.stopImmediatePropagation();
    var mmbWasLocked = axisLocked;
    var fromClientMmb = getSyntheticPointerClient();
    if (axisLocked) {
      axisLocked = false;
    } else {
      var sdx = lastSegment.dx, sdy = lastSegment.dy;
      if (sdx === 0 && sdy === 0 && dragStartClient) {
        sdx = last.x - dragStartClient.x;
        sdy = last.y - dragStartClient.y;
      }
      axisMode = Math.abs(sdx) > Math.abs(sdy) ? 'h' : 'v';
      axisLocked = true;
    }
    if (axisLocked && !mmbWasLocked) emitRampOntoLockedAxis(fromClientMmb);
