    removeBboxSnapGuideGrab();
    gdragBboxStartRect = null;
  };

  document.addEventListener('keydown', function (e) {
    if (e.key && e.key.toLowerCase() === 'g' && !dragging) {
      if (window.__scaleSelectionScaling) return;
      if (window.__rotateSelectionRotating) return;
      var t = e.target;
      var isTyping = typeof window.__adamIsTypingTarget === 'function'
        ? window.__adamIsTypingTarget(t)
        : !!(t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable));
      if (isTyping) return;
      var multi = window.__multiSelectedBlocks || [];
      if (multi.length > 1) return;
      e.preventDefault();
      startDrag();
    }
  }, true);

  window.addEventListener('blur', function () {
    endDrag({ cancel: false });
  });

  window.__grabBlockStartGDragAfterDuplicate = function () {
    if (dragging) return;
    if (window.__grabBlockDragging) return;
    if (window.__scaleSelectionScaling) return;
    if (window.__rotateSelectionRotating) return;
    if (typeof window.__multiSelectCircleSelectActive === 'function' && window.__multiSelectCircleSelectActive()) return;
    var multi = window.__multiSelectedBlocks || [];
    if (multi.length > 1) return;
    if (!Blockly || !Blockly.selected) return;
    var b = Blockly.selected;
    try {
      if (b.isInFlyout) return;
    } catch (e) { return; }
    startDrag();
  };
})();`;
}
</script>
