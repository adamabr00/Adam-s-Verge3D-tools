      var dpx = pt.x - dragStartClient.x;
      var dpy = pt.y - dragStartClient.y;
      var deltaWs = pixelDeltaToWorkspaceDeltaGrab(ws, dpx, dpy);
      var axisSnap = 'both';
      if (axisLocked) axisSnap = axisMode === 'h' ? 'x' : 'y';
      var corr = { dx: 0, dy: 0 };
      if (gdragBboxStartRect && typeof window.__adamGDragBboxSnapDelta === 'function') {
        var snapResult = window.__adamGDragBboxSnapDelta({
          workspace: ws,
          selectionRectStart: gdragBboxStartRect,
          deltaWs: deltaWs,
          movingRootIds: [block.id],
          axisMode: axisSnap,
          ctrlEnable: !!last.ctrlKey
        });
        if (snapResult) {
          corr.dx = snapResult.dx || 0;
          corr.dy = snapResult.dy || 0;
          if (last.ctrlKey) updateBboxSnapGuideGrab(ws, snapResult);
          else removeBboxSnapGuideGrab();
        } else {
          removeBboxSnapGuideGrab();
        }
      } else {
        removeBboxSnapGuideGrab();
      }
      var adjWs = { x: deltaWs.x + corr.dx, y: deltaWs.y + corr.dy };
      var adjPx = workspaceDeltaToPixelDeltaGrab(ws, adjWs.x, adjWs.y);
      var clientOut = { x: dragStartClient.x + adjPx.x, y: dragStartClient.y + adjPx.y };
      lastGDragMoveClient = clientOut;
      fire('pointermove', document, { buttons: 1, clientX: clientOut.x, clientY: clientOut.y });
    };
    document.addEventListener('mousemove', moveProxy, true);

    overlay = makeOverlay();
    suppressCtx = function (e) { e.preventDefault(); };
    window.addEventListener('contextmenu', suppressCtx, true);
  };

  const endDrag = function (opts) {
    var cancel = opts && opts.cancel;
    if (!dragging) return;

    var b = block;
    var snap = connSnap;
    var rp = restorePos;

    if (moveProxy) document.removeEventListener('mousemove', moveProxy, true);
    moveProxy = null;

    dragging = false;

    var ptUp = lastGDragMoveClient || getSyntheticPointerClient();
    lastGDragMoveClient = null;
    fire('pointerup', document, { buttons: 0, clientX: ptUp.x, clientY: ptUp.y });

    window.__grabBlockDragging = false;

    if (overlay && overlay.parentNode) overlay.parentNode.removeChild(overlay);
    overlay = null;

    if (suppressCtx) window.removeEventListener('contextmenu', suppressCtx, true);
    suppressCtx = null;

    if (cancel && b) {
      var restoreAll = function () {
        try {
          if (rp) {
            if (typeof b.moveTo === 'function' && Blockly.utils && Blockly.utils.Coordinate) {
              b.moveTo(new Blockly.utils.Coordinate(rp.x, rp.y));
            } else if (typeof b.getRelativeToSurfaceXY === 'function' && typeof b.moveBy === 'function') {
              const cur = b.getRelativeToSurfaceXY();
              var dx = rp.x - cur.x, dy = rp.y - cur.y;
              if (dx || dy) b.moveBy(dx, dy);
            }
          }
