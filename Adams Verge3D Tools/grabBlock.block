      if (!dragging) return;
      e.preventDefault(); e.stopPropagation();
      if (e.stopImmediatePropagation) e.stopImmediatePropagation();
      var cancel = (e.button === 2);
      endDrag({ cancel: cancel });
    }, true);
    document.body.appendChild(el);
    return el;
  };

  const startDrag = function () {
    const svg = getSelectedSvg();
    block = getBlock();
    if (!svg || !block) { console.warn('[G-drag] No selected block.'); return; }

    if (typeof block.getRelativeToSurfaceXY !== 'function') {
      console.warn('[G-drag] Block has no getRelativeToSurfaceXY.');
      return;
    }
    const ws = block.workspace;
    if (!ws) { console.warn('[G-drag] No workspace.'); return; }

    const p = block.getRelativeToSurfaceXY();
    restorePos = { x: p.x, y: p.y };
    connSnap = snapshotConnections(block);

    dragStartClient = { x: last.x, y: last.y };
    lastSegment = { dx: 0, dy: 0 };
    axisLocked = false;
    try {
      dragStartPointerWs = clientToWorkspaceGrab(ws, last.x, last.y);
    } catch (e0) {
      dragStartPointerWs = null;
    }
    removeAxisGuideGrab();
    removeBboxSnapGuideGrab();

    gdragBboxStartRect = null;
    try {
      if (typeof block.getBoundingRectangle === 'function') {
