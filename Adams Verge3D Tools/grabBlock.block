        axisLocked = true;
      } else {
        axisMode = 'h';
        axisLocked = true;
      }
    } else {
      if (axisLocked && axisMode === 'v') axisLocked = false;
      else if (axisLocked && axisMode === 'h') {
        axisMode = 'v';
        axisLocked = true;
      } else {
        axisMode = 'v';
        axisLocked = true;
