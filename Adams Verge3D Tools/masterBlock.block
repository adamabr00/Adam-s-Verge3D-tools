<template color="#5a6d8d" prev="true" next="true"
  tooltip="Master block that loads all Adam's Awesome Tools features at once.">
  <dummy><label>Adam's Awesome Tools - Master</label></dummy>
  <statement name="DO"></statement>
</template>

<script>
function code(block) {
  const toolsCode = Blockly.JavaScript.statementToCode(block, 'DO') || '';
  return `(function () {
    ${toolsCode}
  })();`;
}
</script>
